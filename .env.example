NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase API Keys (New Format)
# Safe for browser/client-side use (requires RLS)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Elevated privileges - SERVER-SIDE ONLY (bypasses RLS)
SUPABASE_SECRET_KEY=sb_secret_...

# Legacy Keys (kept for transition if needed)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

PROFESSIONAL_ACCESS_KEY=your-professional-access-key
JWT_SECRET=your-jwt-secret
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=your-google-apps-script-url
